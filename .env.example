# ─────────────────────────────────────────────────────────────
# TurnoApp — Environment Variables
# Copy this to .env and fill in real values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────
# Found in: Supabase Dashboard → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY   # Never expose in Flutter app

# ── Mercado Pago ──────────────────────────────────────────────
# Found in: https://www.mercadopago.cl/developers/panel/app
# Use TEST credentials for development, PROD credentials for launch
MP_ACCESS_TOKEN=APP_USR-0000000000000000-000000-YOUR_ACCESS_TOKEN
MP_PUBLIC_KEY=APP_USR-YOUR_PUBLIC_KEY         # Only if using MP JS SDK in web
MP_WEBHOOK_SECRET=YOUR_WEBHOOK_SHARED_SECRET  # Set in MP notification settings

# ── App ───────────────────────────────────────────────────────
# The public HTTPS URL where your app is hosted
APP_BASE_URL=https://turnoapp.cl

# ── Flutter build (passed via --dart-define) ──────────────────
# Run: flutter build web \
#   --dart-define=SUPABASE_URL=$SUPABASE_URL \
#   --dart-define=SUPABASE_ANON_KEY=$SUPABASE_ANON_KEY
