# =============================================================
# TurnoApp — .gitignore
# Covers: Flutter/Dart, Supabase (Deno/TS), Node/npm, OS files
# =============================================================

# ── Secrets & environment ─────────────────────────────────────
.env
.env.local
.env.*.local
.env.production
.env.staging
# Keep .env.example (safe template, no real values)

# Supabase local secrets
supabase/.env
supabase/functions/**/.env

# ── Flutter / Dart ────────────────────────────────────────────
# Build outputs
turnoapp/build/
turnoapp/.dart_tool/
turnoapp/.flutter-plugins
turnoapp/.flutter-plugins-dependencies
turnoapp/.packages

# Generated files
turnoapp/**/*.g.dart
turnoapp/**/*.freezed.dart
turnoapp/**/*.mocks.dart

# Platform-specific generated code
turnoapp/android/
turnoapp/linux/
turnoapp/macos/
turnoapp/windows/

# Pub cache & lock (keep pubspec.lock for reproducible builds)
# turnoapp/pubspec.lock  ← intentionally NOT ignored

# ── Supabase ──────────────────────────────────────────────────
# Local dev state
supabase/.temp/
supabase/.branches/

# Supabase CLI config with local credentials
# (supabase/config.toml is safe to commit — no secrets)

# ── Node / Deno / npm ─────────────────────────────────────────
node_modules/
.npm
.pnpm-store/
dist/
*.tsbuildinfo

# ── IDE & editors ─────────────────────────────────────────────
.idea/
.vscode/
*.iml
*.swp
*.swo
*.swn
.DS_Store
Thumbs.db

# ── OS ────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Logs ─────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Certificates & keys ───────────────────────────────────────
*.pem
*.p12
*.p8
*.keystore
*.jks
key.properties
google-services.json
GoogleService-Info.plist
